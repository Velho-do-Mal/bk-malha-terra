# =========================================================
# BK Malha de Terra - Variáveis de ambiente
# =========================================================
# Copie este arquivo para .env e preencha com seus valores.
# NUNCA commite o .env no Git.
# =========================================================

# Banco de dados Neon PostgreSQL
# Formato: postgresql://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_URL=postgresql://USUARIO:SENHA@HOST.neon.tech/neondb?sslmode=require

# Schema utilizado dentro do banco
DB_SCHEMA=bk_malha_terra

# Streamlit
STREAMLIT_SERVER_PORT=8501

# Identificação BK (caminho relativo)
BK_LOGO_PATH=assets/bk_logo.png
BK_EMPRESA_NOME=Barabach & Knopp Engenharia e Tecnologia
BK_EMPRESA_CNPJ=00.000.000/0001-00

# Ambiente
ENVIRONMENT=development
